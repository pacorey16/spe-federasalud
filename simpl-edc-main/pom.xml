        <!-- dependencies required for infrastructure deployment -->
        <dependency>
            <groupId>com.ionoscloud.edc</groupId>
            <artifactId>data-plane-edc-simpl-infrastructure</artifactId>
            <version>{ionosEdcSimplInfraVersion}</version>
            <scope>system</scope>
