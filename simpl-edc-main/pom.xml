<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>eu.europa.ec.simpl</groupId>
    <artifactId>simpledc</artifactId>
    <version>${env.PROJECT_RELEASE_VERSION}</version>

    <properties>
        <maven.compiler.source>17</maven.compiler.source>
        <maven.compiler.target>17</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>

        <edc>0.10.1</edc>
        <ionosEdcSimplInfraVersion>1.0.1</ionosEdcSimplInfraVersion>
        <eclipseGroupId>org.eclipse.edc</eclipseGroupId>
        <edcForkedRepositoryProjectId>958</edcForkedRepositoryProjectId>
        <s3PluginForkProjectId>1259</s3PluginForkProjectId>
        <minio.s3.version>0.0.1</minio.s3.version>
    </properties>

    <dependencies>
        <!-- Minio S3 Extension JARs - Now from GitLab Maven Repository -->
        <dependency>
            <groupId>fr.gxfs.edc</groupId>
            <artifactId>minio-s3-core</artifactId>
            <version>${minio.s3.version}</version>
        </dependency>
        <dependency>
            <groupId>fr.gxfs.edc</groupId>
            <artifactId>minio-s3-data-plane</artifactId>
            <version>${minio.s3.version}</version>
        </dependency>
        <dependency>
            <groupId>fr.gxfs.edc</groupId>
            <artifactId>minio-s3-control-plane</artifactId>
            <version>${minio.s3.version}</version>
        </dependency>
        <!-- Minio client still needed as transitive dependency -->
        <dependency>
            <groupId>io.minio</groupId>
            <artifactId>minio</artifactId>
            <version>8.6.0</version>
        </dependency>
        <dependency>
            <groupId>com.nimbusds</groupId>
            <artifactId>nimbus-jose-jwt</artifactId>
            <version>9.47</version>
        </dependency>
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <version>1.18.36</version>
        </dependency>

        <dependency>
            <groupId>${eclipseGroupId}</groupId>
            <artifactId>connector-core</artifactId>
            <version>forked-1.1.10</version>
        </dependency>
        <dependency>
            <groupId>org.eclipse.edc</groupId>
            <artifactId>keys-lib</artifactId>
            <version>${edc}</version>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>${eclipseGroupId}</groupId>
            <artifactId>control-api-configuration</artifactId>
            <version>${edc}</version>
            <scope>runtime</scope>
        </dependency>
        <dependency>
            <groupId>${eclipseGroupId}</groupId>
