        </dependency>
        <dependency>
            <groupId>${eclipseGroupId}</groupId>
            <artifactId>control-plane-core</artifactId>
            <version>${edc}</version>
        </dependency>
        <dependency>
            <groupId>${eclipseGroupId}</groupId>
            <artifactId>transaction-local</artifactId>
            <version>${edc}</version>
        </dependency>

        <!--postgres dependencies-->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <version>42.7.8</version>
