        </dependency>

        <!-- MinIO Extensions Dependencies -->
        <dependency>
            <groupId>${eclipseGroupId}</groupId>
            <artifactId>data-plane-util</artifactId>
            <version>${edc}</version>
        </dependency>

        <!--        test dependencies-->

        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-junit-jupiter</artifactId>
            <version>5.14.1</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <version>3.26.3</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter-params</artifactId>
            <version>5.11.2</version>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.eclipse.edc</groupId>
            <artifactId>jersey-core</artifactId>
            <version>${edc}</version>
            <classifier>test-fixtures</classifier>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.eclipse.edc</groupId>
            <artifactId>junit</artifactId>
            <version>${edc}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>io.rest-assured</groupId>
            <artifactId>rest-assured</artifactId>
            <version>5.5.0</version>
            <scope>test</scope>
        </dependency>

    </dependencies>

    <!-- Added it in order to remove protobuf-java vulnerability from org.eclipse.edc:keys-lib:0.10.1 .
    Once EDC version is updated to at least 0.13.0 this dependency can be removed   -->
    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>com.google.protobuf</groupId>
                <artifactId>protobuf-java</artifactId>
                <version>4.31.1</version>
            </dependency>
            <dependency>
                <!-- Added it in order to remove  vulnerability from org.glassfish.jersey.core:jersey-client@3.1.9 .
                Once EDC version is updated to at least 0.11.0 and update in minio.s3.version this dependency can
                be removed   -->
                <groupId>org.glassfish.jersey.core</groupId>
                <artifactId>jersey-client</artifactId>
                <version>3.1.10</version>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <repositories>
        <repository>
            <id>gitlab-maven</id>
            <!--suppress UnresolvedMavenProperty -->
            <url>https://code.europa.eu/api/v4/projects/${edcForkedRepositoryProjectId}/packages/maven</url>
        </repository>
        <repository>
            <id>europa-maven</id>
            <url>https://code.europa.eu/api/v4/projects/${s3PluginForkProjectId}/packages/maven</url>
        </repository>
        <repository>
            <id>central</id>
            <url>https://repo.maven.apache.org/maven2</url>
        </repository>
    </repositories>

    <build>
        <plugins>
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <version>3.5.7</version>
                <executions>
                    <execution>
                        <id>package</id>
                        <goals>
                            <goal>repackage</goal>
                        </goals>
                        <configuration>
                            <mainClass>org.eclipse.edc.boot.system.runtime.BaseRuntime</mainClass>
                        </configuration>
                    </execution>
                </executions>
                <configuration>
                    <includeSystemScope>true</includeSystemScope>
                    <finalName>basic-connector</finalName>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.jacoco</groupId>
                <artifactId>jacoco-maven-plugin</artifactId>
                <version>0.8.12</version>
                <executions>
                    <execution>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
