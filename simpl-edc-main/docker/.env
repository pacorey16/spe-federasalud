CONSUMER_HTTP_PORT: 29191
CONSUMER_MANAGEMENT_PORT: 29193
CONSUMER_PROTOCOL_PORT: 29194
CONSUMER_PUBLIC_PORT: 29291
CONSUMER_CONTROL_PORT: 29192

PROVIDER_HTTP_PORT: 19191
PROVIDER_MANAGEMENT_PORT: 19193
PROVIDER_PROTOCOL_PORT: 19194
PROVIDER_PUBLIC_PORT: 19291
PROVIDER_CONTROL_PORT: 19192

WEB_HTTP_PATH: /api
WEB_HTTP_MANAGEMENT_PATH: /management
WEB_HTTP_PROTOCOL_PATH: /protocol
WEB_HTTP_PUBLIC_PATH: /public
WEB_HTTP_CONTROL_PATH: /control

EDC_DATASOURCE_DEFAULT_USER: postgres
EDC_DATASOURCE_DEFAULT_PASSWORD: postgres
EDC_SQL_SCHEMA_AUTOCREATE: true

VAULT_ADDRESS: http://host.docker.internal:8200
VAULT_TOKEN: test-token

